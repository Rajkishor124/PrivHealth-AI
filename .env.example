# ──────────────────────────────────────────────
# PrivHealth AI — Environment Variables
# Copy to .env and fill in values
# Generate keys: openssl rand -base64 32
# ──────────────────────────────────────────────

# PostgreSQL (docker-compose)
POSTGRES_DB=privhealthai
POSTGRES_USER=privhealthai
POSTGRES_PASSWORD=privhealthai

# Backend
DB_URL=jdbc:postgresql://localhost:5433/privhealthai
DB_USERNAME=privhealthai
DB_PASSWORD=privhealthai
JWT_SECRET=<base64-256-bit-key>
JWT_EXPIRATION_SECONDS=3600
AES_KEY=<base64-256-bit-key>
HMAC_KEY=<base64-256-bit-key>
ML_SERVICE_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Frontend
VITE_API_BASE_URL=http://localhost:8080/api

# ML Service
ML_PORT=8000
